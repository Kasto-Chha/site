# Copy to .env.local or set env vars in your shell before running the scripts
# Required by the app and API seeder:
NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=public-anon-key

# Service role key (server-only). Keep this secret.
SUPABASE_SERVICE_ROLE_KEY=service_role_...

# Anthropic (Claude) API key — powers the AI chat at /chat (server-only).
# Get one at https://console.anthropic.com/. Format: sk-ant-api03-...
ANTHROPIC_API_KEY=sk-ant-api03-...

# Clerk auth keys (required for sign-in and posting).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_...
CLERK_SECRET_KEY=sk_...
